<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
                             http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

  <display-name>Hotel Reservation System</display-name>

  <!-- Login Servlet -->
  <servlet>
    <servlet-name>LoginServlet</servlet-name>
    <servlet-class>
      com.hotel.reservation.presentation.servlet.LoginServlet
    </servlet-class>
  </servlet>

  <servlet-mapping>
    <servlet-name>LoginServlet</servlet-name>
    <url-pattern>/login</url-pattern>
  </servlet-mapping>

  <!-- User Registration Servlet -->
  <servlet>
    <servlet-name>UserServlet</servlet-name>
    <servlet-class>
      com.hotel.reservation.presentation.servlet.UserServlet
    </servlet-class>
  </servlet>

  <servlet-mapping>
    <servlet-name>UserServlet</servlet-name>
    <url-pattern>/user</url-pattern>
  </servlet-mapping>

  <!-- Default page -->
  <welcome-file-list>
    <welcome-file>login.jsp</welcome-file>
  </welcome-file-list>

  <!-- Logout Servlet -->
  <servlet>
    <servlet-name>LogoutServlet</servlet-name>
    <servlet-class>
      com.hotel.reservation.presentation.servlet.LogoutServlet
    </servlet-class>
  </servlet>

  <servlet-mapping>
    <servlet-name>LogoutServlet</servlet-name>
    <url-pattern>/logout</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>ReservationServlet</servlet-name>
    <servlet-class>
      com.hotel.reservation.presentation.servlet.ReservationServlet
    </servlet-class>
  </servlet>

  <servlet-mapping>
    <servlet-name>ReservationServlet</servlet-name>
    <url-pattern>/reservation</url-pattern>
  </servlet-mapping>

  <servlet-mapping>
    <servlet-name>ReservationServlet</servlet-name>
    <url-pattern>/reservation-form</url-pattern>
  </servlet-mapping>


  <filter>
    <filter-name>AuthorizationFilter</filter-name>
    <filter-class>
      com.hotel.reservation.presentation.filter.AuthorizationFilter
    </filter-class>
  </filter>

  <filter-mapping>
    <filter-name>AuthorizationFilter</filter-name>
    <url-pattern>/reservation</url-pattern>
  </filter-mapping>

  <filter-mapping>
    <filter-name>AuthorizationFilter</filter-name>
    <url-pattern>/dashboard.jsp</url-pattern>
  </filter-mapping>

  <filter-mapping>
    <filter-name>AuthorizationFilter</filter-name>
    <url-pattern>/admin/*</url-pattern>
  </filter-mapping>


  <servlet>
    <servlet-name>HelpServlet</servlet-name>
    <servlet-class>
      com.hotel.reservation.presentation.servlet.HelpServlet
    </servlet-class>
  </servlet>

  <servlet-mapping>
    <servlet-name>HelpServlet</servlet-name>
    <url-pattern>/help</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>CancelReservationServlet</servlet-name>
    <servlet-class>
      com.hotel.reservation.presentation.servlet.CancelReservationServlet
    </servlet-class>
  </servlet>

  <servlet-mapping>
    <servlet-name>CancelReservationServlet</servlet-name>
    <url-pattern>/cancel-reservation</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>GuestServlet</servlet-name>
    <servlet-class>
      com.hotel.reservation.presentation.servlet.GuestServlet
    </servlet-class>
  </servlet>

  <servlet-mapping>
    <servlet-name>GuestServlet</servlet-name>
    <url-pattern>/guests</url-pattern>
  </servlet-mapping>



  <filter-mapping>
    <filter-name>AuthorizationFilter</filter-name>
    <url-pattern>/*</url-pattern>
  </filter-mapping>



  <!--
  <error-page>
      <exception-type>java.lang.Exception</exception-type>
      <location>/db-error.jsp</location>
  </error-page>
  -->

</web-app>
